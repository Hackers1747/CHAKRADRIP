<footer class="site-footer" role="contentinfo">

  <!-- Top border glow -->
  <div class="footer__border" aria-hidden="true"></div>

  <div class="footer__main container--wide">

    <!-- Brand column -->
    <div class="footer__brand">
      <a href="{{ routes.root_url }}" class="footer__logo">{{ shop.name }}</a>
      <p class="footer__tagline">Where chakra flows, drip follows.</p>

      {%- if section.settings.show_social -%}
        <div class="footer__socials">
          {%- if settings.social_instagram_link != blank -%}
            <a href="{{ settings.social_instagram_link }}" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
              Instagram
            </a>
          {%- endif -%}
          {%- if settings.social_tiktok_link != blank -%}
            <a href="{{ settings.social_tiktok_link }}" class="footer__social-link" aria-label="TikTok" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.85a8.18 8.18 0 004.78 1.52V6.93a4.85 4.85 0 01-1.01-.24z"/>
              </svg>
              TikTok
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <!-- Nav columns -->
    {%- for block in section.blocks -%}
      {%- if block.type == 'link_list' -%}
        <div class="footer__col" {{ block.shopify_attributes }}>
          <h3 class="footer__col-title">{{ block.settings.heading }}</h3>
          {%- if block.settings.menu != blank -%}
            <ul class="footer__links" role="list">
              {%- for link in block.settings.menu.links -%}
                <li>
                  <a href="{{ link.url }}" class="footer__link">{{ link.title }}</a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}

    <!-- Newsletter -->
    {%- if section.settings.show_newsletter -%}
      <div class="footer__newsletter">
        <h3 class="footer__col-title">Stay In The Drip</h3>
        <p class="footer__newsletter-text">New drops. First access. Nothing else.</p>
        {%- form 'customer', id: 'footer-newsletter' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="footer__newsletter-form">
            <input
              type="email"
              name="contact[email]"
              id="footer-email"
              placeholder="your@email.com"
              required
              autocomplete="email"
              aria-label="Email address"
            >
            <button type="submit" class="btn btn--primary btn--sm">JOIN</button>
          </div>
          {%- if form.posted_successfully? -%}
            <p class="footer__newsletter-success">You're in. Watch the drop. ðŸ”¥</p>
          {%- endif -%}
        {%- endform -%}
      </div>
    {%- endif -%}

  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom">
    <div class="container--wide footer__bottom-inner">
      <p class="footer__copy">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
      </p>
      <div class="footer__payment-icons" aria-label="Accepted payment methods">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
        {%- endfor -%}
      </div>
    </div>
  </div>

</footer>

<!-- Red horizontal line top -->
<style>
  .site-footer {
    background:  var(--cd-surface-1);
    margin-top:  var(--space-24);
    position:    relative;
  }

  .footer__border {
    height:     2px;
    background: linear-gradient(90deg, transparent, var(--cd-blood-red) 20%, var(--cd-neon-red) 50%, var(--cd-blood-red) 80%, transparent);
    box-shadow: 0 0 12px rgba(255, 26, 26, 0.4);
  }

  .footer__main {
    display:               grid;
    grid-template-columns: 2fr 1fr 1fr 2fr;
    gap:                   var(--space-12);
    padding:               var(--space-16) var(--page-padding);
  }

  /* â”€â”€ Brand â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
  .footer__logo {
    font-family:    var(--font-display);
    font-size:      var(--text-3xl);
    letter-spacing: 0.06em;
    color:          var(--cd-white);
    text-decoration: none;
    display:        block;
    margin-bottom:  var(--space-3);
    transition:     color var(--ease-fast);
  }

  .footer__logo:hover { color: var(--cd-neon-red); }

  .footer__tagline {
    font-family:    var(--font-mono);
    font-size:      var(--text-sm);
    color:          var(--cd-text-muted);
    letter-spacing: 0.08em;
    font-style:     italic;
    margin-bottom:  var(--space-6);
  }

  .footer__socials {
    display:    flex;
    flex-direction: column;
    gap:        var(--space-3);
  }

  .footer__social-link {
    display:        inline-flex;
    align-items:    center;
    gap:            var(--space-2);
    font-family:    var(--font-display);
    font-size:      var(--text-base);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color:          var(--cd-text-muted);
    transition:     color var(--ease-fast);
    text-decoration: none;
  }

  .footer__social-link:hover { color: var(--cd-neon-red); }

  /* â”€â”€ Columns â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
  .footer__col-title {
    font-family:    var(--font-display);
    font-size:      var(--text-lg);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color:          var(--cd-neon-red);
    margin-bottom:  var(--space-4);
  }

  .footer__links {
    list-style: none;
    display:    flex;
    flex-direction: column;
    gap:        var(--space-3);
  }

  .footer__link {
    font-size:   var(--text-base);
    color:       var(--cd-text-muted);
    text-decoration: none;
    transition:  color var(--ease-fast), padding-left var(--ease-fast);
    display:     block;
  }

  .footer__link:hover {
    color:        var(--cd-text);
    padding-left: var(--space-2);
  }

  /* â”€â”€ Newsletter â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
  .footer__newsletter-text {
    font-size:     var(--text-sm);
    color:         var(--cd-text-muted);
    margin-bottom: var(--space-4);
  }

  .footer__newsletter-form {
    display: flex;
    gap:     var(--space-2);
  }

  .footer__newsletter-form input {
    flex:         1;
    border-color: var(--cd-surface-3);
    font-size:    var(--text-sm);
  }

  .footer__newsletter-success {
    margin-top:  var(--space-3);
    font-family: var(--font-mono);
    font-size:   var(--text-sm);
    color:       var(--cd-neon-red);
  }

  /* â”€â”€ Bottom bar â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
  .footer__bottom {
    border-top: 1px solid var(--cd-surface-3);
  }

  .footer__bottom-inner {
    display:         flex;
    align-items:     center;
    justify-content: space-between;
    padding:         var(--space-6) var(--page-padding);
    gap:             var(--space-4);
    flex-wrap:       wrap;
  }

  .footer__copy {
    font-family: var(--font-mono);
    font-size:   var(--text-xs);
    color:       var(--cd-text-ghost);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin:      0;
  }

  .footer__payment-icons {
    display:     flex;
    align-items: center;
    gap:         var(--space-2);
    flex-wrap:   wrap;
  }

  .footer__payment-icon {
    height:       24px;
    width:        auto;
    opacity:      0.4;
    filter:       grayscale(1) brightness(2);
    transition:   opacity var(--ease-fast);
  }

  .footer__payment-icon:hover { opacity: 0.7; }

  /* â”€â”€ Responsive â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ */
  @media (max-width: 1024px) {
    .footer__main { grid-template-columns: 1fr 1fr; }
    .footer__brand { grid-column: 1 / -1; }
  }

  @media (max-width: 600px) {
    .footer__main { grid-template-columns: 1fr; gap: var(--space-8); }
    .footer__newsletter-form { flex-direction: column; }
    .footer__newsletter-form .btn { width: 100%; }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social links",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading",
          "default": "Shop"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        { "type": "link_list", "settings": { "heading": "Shop" } },
        { "type": "link_list", "settings": { "heading": "Info" } }
      ]
    }
  ]
}
{% endschema %}