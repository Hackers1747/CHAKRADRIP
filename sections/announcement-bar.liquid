{% comment %}
  ============================================
  CHAKRADRIP â€” Announcement Bar (Marquee)
  File: sections/announcement-bar.liquid
  ============================================
{% endcomment %}

<div class="chakra-announcement-bar" style="background-color: {{ section.settings.bg_color }};">
  <div class="chakra-marquee-wrapper">
    <div class="chakra-marquee-track" style="animation-duration: {{ section.settings.speed }}s;">
      {% for i in (1..8) %}
        <span class="chakra-marquee-text" style="color: {{ section.settings.text_color }}; font-size: {{ section.settings.font_size }}px;">
          {{ section.settings.message }}
        </span>
        <span class="chakra-marquee-sep" style="color: {{ section.settings.accent_color }};">
          {{ section.settings.separator }}
        </span>
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .chakra-announcement-bar {
    width: 100%;
    overflow: hidden;
    padding: {{ section.settings.bar_padding }}px 0;
    position: relative;
    z-index: 10;
  }

  .chakra-marquee-wrapper {
    overflow: hidden;
    width: 100%;
  }

  .chakra-marquee-track {
    display: flex;
    align-items: center;
    white-space: nowrap;
    width: max-content;
    animation: chakra-scroll linear infinite;
    animation-duration: inherit;
  }

  {% if section.settings.pause_on_hover %}
  .chakra-marquee-track:hover {
    animation-play-state: paused;
  }
  {% endif %}

  .chakra-marquee-text {
    display: inline-block;
    padding: 0 16px;
    font-weight: {{ section.settings.font_weight }};
    letter-spacing: {{ section.settings.letter_spacing }}px;
    text-transform: {{ section.settings.text_transform }};
  }

  .chakra-marquee-sep {
    display: inline-block;
    padding: 0 8px;
    font-size: 1.1em;
  }

  @keyframes chakra-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (max-width: 768px) {
    .chakra-marquee-text {
      font-size: {{ section.settings.font_size | minus: 2 }}px !important;
    }
  }
</style>

