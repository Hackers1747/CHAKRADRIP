<!doctype html>
<html
  lang="{{ request.locale.iso_code }}"
  class="no-js"
  data-color-scheme="dark"
>
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, height=device-height">
  <meta name="theme-color" content="#0a0a0a">

  <!-- ============================================================
       TITLE & META
  ============================================================ -->
  <title>
    {{ page_title }}
    {%- if current_tags %} &ndash; {{ 'general.meta.tags' | t: tags: current_tags | join: ', ' }}{% endif -%}
    {%- if current_page != 1 %} &ndash; {{ 'general.meta.page' | t: page: current_page }}{% endif -%}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>

  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}

  <link rel="canonical" href="{{ canonical_url }}">

  {%- if settings.favicon != blank %}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif %}

  <!-- ============================================================
       PRECONNECTS
  ============================================================ -->
  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- ============================================================
       FONTS
  ============================================================ -->
  <link
    href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap"
    rel="stylesheet"
  >

  {{ content_for_header }}

  <!-- ============================================================
       DESIGN TOKENS
  ============================================================ -->
  <style>
    :root {
      --cd-black:        #0a0a0a;
      --cd-surface-1:    #0f0f0f;
      --cd-surface-2:    #141414;
      --cd-surface-3:    #1c1c1c;
      --cd-neon-red:     #ff1a1a;
      --cd-blood-red:    #8b0000;
      --cd-crimson:      #c0392b;
      --cd-text:         #e8e8e8;
      --cd-text-muted:   #666666;
      --cd-text-ghost:   #333333;
      --cd-white:        #ffffff;
      --cd-glow-red:     0 0 8px rgba(255,26,26,0.6), 0 0 24px rgba(255,26,26,0.25);
      --cd-glow-blood:   0 0 12px rgba(139,0,0,0.5);
      --font-display:    'Bebas Neue', 'Impact', sans-serif;
      --font-body:       'Rajdhani', 'Arial Narrow', sans-serif;
      --font-mono:       'Share Tech Mono', 'Courier New', monospace;
      --text-xs:   0.75rem;
      --text-sm:   0.875rem;
      --text-base: 1rem;
      --text-md:   1.125rem;
      --text-lg:   1.25rem;
      --text-xl:   1.5rem;
      --text-2xl:  2rem;
      --text-3xl:  3rem;
      --text-4xl:  4.5rem;
      --text-5xl:  7rem;
      --space-1:   4px;
      --space-2:   8px;
      --space-3:   12px;
      --space-4:   16px;
      --space-6:   24px;
      --space-8:   32px;
      --space-12:  48px;
      --space-16:  64px;
      --space-24:  96px;
      --space-32:  128px;
      --max-width:     1440px;
      --content-width: 1200px;
      --nav-height:    64px;
      --announce-height: 40px;
      --page-padding:  clamp(16px, 4vw, 48px);
      --radius-sharp: 1px;
      --radius-sm:    4px;
      --radius-md:    6px;
      --ease-fast:   0.12s cubic-bezier(0.4,0,0.2,1);
      --ease-med:    0.25s cubic-bezier(0.4,0,0.2,1);
      --ease-slow:   0.45s cubic-bezier(0.4,0,0.2,1);
      --ease-spring: 0.5s cubic-bezier(0.34,1.56,0.64,1);
      --z-base:    1;
      --z-raised:  10;
      --z-dropdown:100;
      --z-sticky:  200;
      --z-overlay: 300;
      --z-modal:   400;
      --z-toast:   500;
    }
  </style>

  <!-- ============================================================
       GLOBAL BASE STYLES
  ============================================================ -->
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html {
      font-size: 16px;
      scroll-behavior: smooth;
      -webkit-text-size-adjust: 100%;
      scrollbar-color: var(--cd-blood-red) var(--cd-surface-1);
      scrollbar-width: thin;
    }

    html.no-js .js-only    { display: none !important; }
    html.js    .no-js-only { display: none !important; }

    ::-webkit-scrollbar             { width: 4px; }
    ::-webkit-scrollbar-track       { background: var(--cd-surface-1); }
    ::-webkit-scrollbar-thumb       { background: var(--cd-blood-red); border-radius: 2px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--cd-neon-red); }

    ::selection { background: var(--cd-neon-red); color: var(--cd-black); }

    body {
      font-family: var(--font-body);
      font-size: var(--text-md);
      font-weight: 400;
      line-height: 1.6;
      color: var(--cd-text);
      background-color: var(--cd-black);
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      overflow-x: hidden;
    }

    /* Noise texture overlay */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='1'/%3E%3C/svg%3E");
      opacity: 0.03;
      pointer-events: none;
      z-index: var(--z-toast);
      animation: noise-drift 8s steps(2) infinite;
    }

    @keyframes noise-drift {
      0%,100% { transform:translate(0,0); }
      10%      { transform:translate(-1px,1px); }
      20%      { transform:translate(1px,-1px); }
      30%      { transform:translate(-2px,-1px); }
      40%      { transform:translate(1px,2px); }
      50%      { transform:translate(-1px,1px); }
      60%      { transform:translate(2px,-2px); }
      70%      { transform:translate(0px,2px); }
      80%      { transform:translate(-2px,0px); }
      90%      { transform:translate(1px,-1px); }
    }

    h1,h2,h3,h4,h5,h6 {
      font-family: var(--font-display);
      letter-spacing: 0.04em;
      line-height: 1.05;
      color: var(--cd-white);
      text-transform: uppercase;
    }

    h1 { font-size: clamp(var(--text-3xl), 8vw, var(--text-5xl)); }
    h2 { font-size: clamp(var(--text-2xl), 5vw, var(--text-4xl)); }
    h3 { font-size: clamp(var(--text-xl),  3vw, var(--text-3xl)); }
    h4 { font-size: var(--text-2xl); }
    h5 { font-size: var(--text-xl); }
    h6 { font-size: var(--text-lg); }

    p { margin-bottom: var(--space-4); }
    p:last-child { margin-bottom: 0; }

    a {
      color: var(--cd-neon-red);
      text-decoration: none;
      transition: color var(--ease-fast), opacity var(--ease-fast);
    }
    a:hover { color: var(--cd-white); }

    img, video { max-width: 100%; height: auto; display: block; }

    button, [role="button"] { cursor: pointer; font-family: var(--font-body); border: none; background: none; }

    input, select, textarea {
      font-family: var(--font-body);
      font-size: var(--text-base);
      color: var(--cd-text);
      background: var(--cd-surface-2);
      border: 1px solid var(--cd-surface-3);
      border-radius: var(--radius-sm);
      padding: var(--space-3) var(--space-4);
      transition: border-color var(--ease-fast), box-shadow var(--ease-fast);
      outline: none;
      width: 100%;
    }

    input:focus, select:focus, textarea:focus {
      border-color: var(--cd-neon-red);
      box-shadow: 0 0 0 2px rgba(255,26,26,0.15);
    }

    /* Layout */
    .page-wrapper { min-height: 100vh; display: flex; flex-direction: column; }
    .page-main { flex: 1; padding-top: calc(var(--nav-height) + var(--announce-height)); }

    .container        { max-width: var(--content-width); margin: 0 auto; padding: 0 var(--page-padding); }
    .container--wide  { max-width: var(--max-width); margin: 0 auto; padding: 0 var(--page-padding); }
    .container--narrow{ max-width: 800px; margin: 0 auto; padding: 0 var(--page-padding); }

    .visually-hidden {
      position: absolute; width: 1px; height: 1px; padding: 0;
      margin: -1px; overflow: hidden; clip: rect(0,0,0,0);
      white-space: nowrap; border: 0;
    }

    .text-neon  { color: var(--cd-neon-red); }
    .text-blood { color: var(--cd-blood-red); }
    .text-muted { color: var(--cd-text-muted); }
    .text-mono  { font-family: var(--font-mono); }
    .text-upper { text-transform: uppercase; letter-spacing: 0.1em; }
    .glow-red   { text-shadow: var(--cd-glow-red); }

    .divider       { border: none; border-top: 1px solid var(--cd-surface-3); margin: var(--space-8) 0; }
    .divider--red  { border-top-color: var(--cd-blood-red); }

    /* Button system */
    .btn {
      display: inline-flex; align-items: center; justify-content: center;
      gap: var(--space-2); font-family: var(--font-display); font-size: var(--text-lg);
      letter-spacing: 0.08em; text-transform: uppercase;
      padding: var(--space-3) var(--space-8); border-radius: var(--radius-sharp);
      transition: all var(--ease-med); position: relative; overflow: hidden;
      cursor: pointer; white-space: nowrap;
    }
    .btn::before {
      content: ''; position: absolute; inset: 0;
      background: linear-gradient(135deg, transparent 40%, rgba(255,255,255,0.05));
      opacity: 0; transition: opacity var(--ease-med);
    }
    .btn:hover::before { opacity: 1; }

    .btn--primary { background: var(--cd-neon-red); color: var(--cd-black); border: 2px solid var(--cd-neon-red); }
    .btn--primary:hover { background: var(--cd-blood-red); border-color: var(--cd-blood-red); color: var(--cd-white); box-shadow: var(--cd-glow-red); transform: translateY(-1px); }
    .btn--outline { background: transparent; color: var(--cd-neon-red); border: 2px solid var(--cd-neon-red); }
    .btn--outline:hover { background: var(--cd-neon-red); color: var(--cd-black); box-shadow: var(--cd-glow-red); transform: translateY(-1px); }
    .btn--ghost { background: transparent; color: var(--cd-text-muted); border: 1px solid var(--cd-surface-3); }
    .btn--ghost:hover { border-color: var(--cd-neon-red); color: var(--cd-neon-red); }
    .btn--lg { padding: var(--space-4) var(--space-12); font-size: var(--text-xl); }
    .btn--sm { padding: var(--space-2) var(--space-4); font-size: var(--text-base); }
    .btn[disabled], .btn.loading { opacity: 0.5; cursor: not-allowed; pointer-events: none; }

    /* Spinner */
    .spinner { width: 20px; height: 20px; border: 2px solid var(--cd-surface-3); border-top-color: var(--cd-neon-red); border-radius: 50%; animation: spin 0.6s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Overlay */
    .overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.75); backdrop-filter: blur(2px); z-index: var(--z-overlay); opacity: 0; visibility: hidden; transition: opacity var(--ease-med), visibility var(--ease-med); }
    .overlay.is-active { opacity: 1; visibility: visible; }

    /* Badge */
    .badge { display: inline-flex; align-items: center; font-family: var(--font-display); font-size: var(--text-xs); letter-spacing: 0.12em; text-transform: uppercase; padding: 2px 8px; border-radius: var(--radius-sharp); }
    .badge--new     { background: var(--cd-neon-red);  color: var(--cd-black); }
    .badge--sold    { background: var(--cd-surface-3); color: var(--cd-text-muted); }
    .badge--limited { background: var(--cd-blood-red); color: var(--cd-white); }

    .accent-bar { display: block; width: 48px; height: 3px; background: linear-gradient(90deg, var(--cd-neon-red), var(--cd-blood-red)); margin-bottom: var(--space-4); }
    .accent-bar--center { margin-left: auto; margin-right: auto; }

    :focus-visible { outline: 2px solid var(--cd-neon-red); outline-offset: 3px; }

    @media (prefers-reduced-motion: reduce) {
      *,*::before,*::after { animation-duration: 0.01ms !important; animation-iteration-count: 1 !important; transition-duration: 0.01ms !important; }
      body::before { animation: none; }
    }

    @media (max-width: 768px) {
      :root { --nav-height: 56px; --announce-height: 36px; }
      h1 { font-size: clamp(var(--text-2xl), 10vw, var(--text-3xl)); }
    }

    /* ============================================================
       ANNOUNCEMENT BAR
    ============================================================ */
    .announcement-bar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: var(--announce-height);
      background: var(--cd-neon-red);
      z-index: calc(var(--z-sticky) + 1);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .announcement-bar__track {
      display: flex;
      gap: var(--space-12);
      animation: announce-scroll 30s linear infinite;
      white-space: nowrap;
    }

    .announcement-bar:hover .announcement-bar__track {
      animation-play-state: paused;
    }

    @keyframes announce-scroll {
      from { transform: translateX(0); }
      to   { transform: translateX(-50%); }
    }

    .announcement-bar__item {
      display: inline-flex;
      align-items: center;
      gap: var(--space-4);
      font-family: var(--font-display);
      font-size: var(--text-sm);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--cd-black);
    }

    .announcement-bar__item::before {
      content: '✦';
      font-size: 8px;
      opacity: 0.7;
    }

    .announcement-bar__close {
      position: absolute;
      right: var(--space-4);
      top: 50%;
      transform: translateY(-50%);
      color: var(--cd-black);
      opacity: 0.7;
      font-size: 18px;
      line-height: 1;
      cursor: pointer;
      transition: opacity var(--ease-fast);
      background: none;
      border: none;
      padding: 4px;
    }
    .announcement-bar__close:hover { opacity: 1; }

    /* ============================================================
       HEADER / NAV
    ============================================================ */
    .site-header {
      position: fixed;
      top: var(--announce-height);
      left: 0;
      right: 0;
      height: var(--nav-height);
      background: rgba(10,10,10,0.92);
      backdrop-filter: blur(16px) saturate(180%);
      -webkit-backdrop-filter: blur(16px) saturate(180%);
      border-bottom: 1px solid var(--cd-surface-3);
      z-index: var(--z-sticky);
      transition: background var(--ease-med), border-color var(--ease-med);
    }

    .site-header.is-scrolled {
      background: rgba(10,10,10,0.98);
      border-bottom-color: var(--cd-blood-red);
    }

    .site-header__inner {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 var(--page-padding);
      height: 100%;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
    }

    /* Logo */
    .site-header__logo {
      display: flex;
      align-items: center;
      justify-content: flex-start;
    }

    .site-header__logo a {
      font-family: var(--font-display);
      font-size: var(--text-2xl);
      letter-spacing: 0.08em;
      color: var(--cd-white);
      text-transform: uppercase;
      text-decoration: none;
      transition: color var(--ease-fast);
      position: relative;
    }

    .site-header__logo a:hover { color: var(--cd-neon-red); }

    .site-header__logo a::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      width: 100%;
      height: 2px;
      background: var(--cd-neon-red);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform var(--ease-med);
    }

    .site-header__logo a:hover::after { transform: scaleX(1); }

    /* Nav links */
    .site-nav {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-8);
      list-style: none;
    }

    .site-nav__item { position: relative; }

    .site-nav__link {
      font-family: var(--font-display);
      font-size: var(--text-base);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--cd-text-muted);
      text-decoration: none;
      padding: var(--space-2) 0;
      transition: color var(--ease-fast);
      position: relative;
      display: block;
    }

    .site-nav__link::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 1px;
      background: var(--cd-neon-red);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform var(--ease-med);
    }

    .site-nav__link:hover,
    .site-nav__link.is-active {
      color: var(--cd-white);
    }

    .site-nav__link:hover::after,
    .site-nav__link.is-active::after { transform: scaleX(1); }

    /* Dropdown */
    .site-nav__dropdown {
      position: absolute;
      top: calc(100% + var(--space-4));
      left: 50%;
      transform: translateX(-50%) translateY(-8px);
      min-width: 200px;
      background: var(--cd-surface-1);
      border: 1px solid var(--cd-surface-3);
      border-top: 2px solid var(--cd-neon-red);
      list-style: none;
      opacity: 0;
      visibility: hidden;
      transition: opacity var(--ease-med), transform var(--ease-med), visibility var(--ease-med);
      z-index: var(--z-dropdown);
    }

    .site-nav__item:hover .site-nav__dropdown {
      opacity: 1;
      visibility: visible;
      transform: translateX(-50%) translateY(0);
    }

    .site-nav__dropdown-link {
      display: block;
      padding: var(--space-3) var(--space-4);
      font-family: var(--font-body);
      font-size: var(--text-sm);
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--cd-text-muted);
      text-decoration: none;
      border-bottom: 1px solid var(--cd-surface-3);
      transition: color var(--ease-fast), background var(--ease-fast), padding-left var(--ease-fast);
    }

    .site-nav__dropdown-link:last-child { border-bottom: none; }
    .site-nav__dropdown-link:hover { color: var(--cd-neon-red); background: var(--cd-surface-2); padding-left: var(--space-6); }

    /* Header actions (right side) */
    .site-header__actions {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: var(--space-4);
    }

    .header-icon-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      color: var(--cd-text-muted);
      text-decoration: none;
      transition: color var(--ease-fast);
      position: relative;
      background: none;
      border: none;
      cursor: pointer;
    }

    .header-icon-btn:hover { color: var(--cd-neon-red); }

    .header-icon-btn svg { width: 20px; height: 20px; stroke: currentColor; fill: none; }

    /* Cart count badge */
    .cart-count {
      position: absolute;
      top: 2px;
      right: 2px;
      min-width: 16px;
      height: 16px;
      background: var(--cd-neon-red);
      color: var(--cd-black);
      font-family: var(--font-display);
      font-size: 10px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0 2px;
      opacity: 0;
      transform: scale(0);
      transition: opacity var(--ease-spring), transform var(--ease-spring);
    }

    .cart-count.has-items { opacity: 1; transform: scale(1); }

    /* Mobile hamburger */
    .hamburger {
      display: none;
      flex-direction: column;
      gap: 5px;
      width: 24px;
      cursor: pointer;
      padding: 8px;
      background: none;
      border: none;
    }

    .hamburger span {
      display: block;
      width: 24px;
      cursor: pointer;
      padding: 8px;
      background: none;
      border: none;
    }

    .hamburger span {
      display: block;
      width: 100%;
      height: 1.5px;
      background: var(--cd-text);
      transition: transform var(--ease-med), opacity var(--ease-med), width var(--ease-med);
      transform-origin: left;
    }

    .hamburger.is-open span:nth-child(1) { transform: rotate(45deg) translate(1px,-1px); }
    .hamburger.is-open span:nth-child(2) { opacity: 0; width: 0; }
    .hamburger.is-open span:nth-child(3) { transform: rotate(-45deg) translate(1px,1px); }

    /* Mobile nav */
    .mobile-nav {
      position: fixed;
      top: calc(var(--announce-height) + var(--nav-height));
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--cd-black);
      z-index: calc(var(--z-sticky) - 1);
      transform: translateX(-100%);
      transition: transform var(--ease-slow);
      overflow-y: auto;
      padding: var(--space-8) var(--page-padding);
    }

    .mobile-nav.is-open { transform: translateX(0); }

    .mobile-nav__list { list-style: none; }

    .mobile-nav__item {
      border-bottom: 1px solid var(--cd-surface-3);
    }

    .mobile-nav__link {
      display: block;
      padding: var(--space-4) 0;
      font-family: var(--font-display);
      font-size: var(--text-2xl);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--cd-text-muted);
      text-decoration: none;
      transition: color var(--ease-fast), padding-left var(--ease-fast);
    }

    .mobile-nav__link:hover { color: var(--cd-neon-red); padding-left: var(--space-4); }

    /* ============================================================
       CART DRAWER
    ============================================================ */
    .cart-drawer {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: min(480px, 100vw);
      background: var(--cd-surface-1);
      border-left: 1px solid var(--cd-surface-3);
      z-index: var(--z-modal);
      transform: translateX(100%);
      transition: transform var(--ease-slow);
      display: flex;
      flex-direction: column;
    }

    .cart-drawer.is-open { transform: translateX(0); }

    .cart-drawer__header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: var(--space-6) var(--space-6) var(--space-4);
      border-bottom: 1px solid var(--cd-surface-3);
      flex-shrink: 0;
    }

    .cart-drawer__title {
      font-family: var(--font-display);
      font-size: var(--text-2xl);
      letter-spacing: 0.08em;
      color: var(--cd-white);
    }

    .cart-drawer__close {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      color: var(--cd-text-muted);
      cursor: pointer;
      transition: color var(--ease-fast);
      background: none;
      border: none;
    }
    .cart-drawer__close:hover { color: var(--cd-neon-red); }
    .cart-drawer__close svg { width: 20px; height: 20px; stroke: currentColor; fill: none; }

    .cart-drawer__body {
      flex: 1;
      overflow-y: auto;
      padding: var(--space-4) var(--space-6);
    }

    .cart-drawer__empty {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100%;
      gap: var(--space-4);
      text-align: center;
      color: var(--cd-text-muted);
    }

    .cart-drawer__empty svg { width: 48px; height: 48px; opacity: 0.3; stroke: currentColor; fill: none; }
    .cart-drawer__empty p { font-family: var(--font-display); font-size: var(--text-xl); letter-spacing: 0.06em; text-transform: uppercase; }

    /* Cart item */
    .cart-item {
      display: grid;
      grid-template-columns: 80px 1fr;
      gap: var(--space-4);
      padding: var(--space-4) 0;
      border-bottom: 1px solid var(--cd-surface-3);
    }

    .cart-item__image {
      width: 80px;
      height: 80px;
      background: var(--cd-surface-2);
      border: 1px solid var(--cd-surface-3);
      overflow: hidden;
      flex-shrink: 0;
    }

    .cart-item__image img { width: 100%; height: 100%; object-fit: cover; }

    .cart-item__info { display: flex; flex-direction: column; gap: var(--space-2); }

    .cart-item__title {
      font-family: var(--font-display);
      font-size: var(--text-lg);
      letter-spacing: 0.04em;
      color: var(--cd-white);
      text-transform: uppercase;
    }

    .cart-item__variant { font-size: var(--text-sm); color: var(--cd-text-muted); }

    .cart-item__meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: auto;
    }

    .cart-item__qty {
      display: flex;
      align-items: center;
      gap: var(--space-2);
    }

    .cart-item__qty-btn {
      width: 24px;
      height: 24px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid var(--cd-surface-3);
      color: var(--cd-text-muted);
      font-size: var(--text-lg);
      line-height: 1;
      cursor: pointer;
      transition: border-color var(--ease-fast), color var(--ease-fast);
      background: none;
    }
    .cart-item__qty-btn:hover { border-color: var(--cd-neon-red); color: var(--cd-neon-red); }

    .cart-item__qty-val {
      font-family: var(--font-mono);
      font-size: var(--text-sm);
      min-width: 24px;
      text-align: center;
      color: var(--cd-text);
    }

    .cart-item__price {
      font-family: var(--font-display);
      font-size: var(--text-lg);
      color: var(--cd-neon-red);
    }

    .cart-item__remove {
      background: none;
      border: none;
      color: var(--cd-text-ghost);
      font-size: var(--text-xs);
      font-family: var(--font-body);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      cursor: pointer;
      transition: color var(--ease-fast);
      padding: 0;
    }
    .cart-item__remove:hover { color: var(--cd-neon-red); }

    .cart-drawer__footer {
      padding: var(--space-4) var(--space-6) var(--space-6);
      border-top: 1px solid var(--cd-surface-3);
      flex-shrink: 0;
    }

    .cart-drawer__subtotal {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: var(--space-4);
    }

    .cart-drawer__subtotal-label {
      font-family: var(--font-display);
      font-size: var(--text-lg);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--cd-text-muted);
    }

    .cart-drawer__subtotal-price {
      font-family: var(--font-display);
      font-size: var(--text-2xl);
      color: var(--cd-white);
    }

    .cart-drawer__checkout {
      width: 100%;
      padding: var(--space-4);
      font-size: var(--text-xl);
    }

    .cart-drawer__note {
      text-align: center;
      font-size: var(--text-xs);
      color: var(--cd-text-muted);
      margin-top: var(--space-3);
    }

    /* ============================================================
       FOOTER
    ============================================================ */
    .site-footer {
      background: var(--cd-surface-1);
      border-top: 1px solid var(--cd-surface-3);
      margin-top: auto;
    }

    .site-footer__top {
      padding: var(--space-16) 0 var(--space-12);
    }

    .site-footer__grid {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 var(--page-padding);
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: var(--space-12);
    }

    .site-footer__brand {}

    .site-footer__logo {
      font-family: var(--font-display);
      font-size: var(--text-3xl);
      letter-spacing: 0.06em;
      color: var(--cd-white);
      text-transform: uppercase;
      text-decoration: none;
      display: block;
      margin-bottom: var(--space-4);
      line-height: 1;
    }

    .site-footer__logo span { color: var(--cd-neon-red); }

    .site-footer__tagline {
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--cd-text-muted);
      margin-bottom: var(--space-6);
    }

    .site-footer__social {
      display: flex;
      gap: var(--space-3);
    }

    .social-link {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border: 1px solid var(--cd-surface-3);
      color: var(--cd-text-muted);
      text-decoration: none;
      transition: border-color var(--ease-fast), color var(--ease-fast), box-shadow var(--ease-fast);
    }

    .social-link:hover {
      border-color: var(--cd-neon-red);
      color: var(--cd-neon-red);
      box-shadow: var(--cd-glow-red);
    }

    .social-link svg { width: 16px; height: 16px; stroke: currentColor; fill: none; }

    .site-footer__col-title {
      font-family: var(--font-display);
      font-size: var(--text-lg);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--cd-white);
      margin-bottom: var(--space-4);
      position: relative;
      padding-bottom: var(--space-3);
    }

    .site-footer__col-title::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 24px;
      height: 2px;
      background: var(--cd-neon-red);
    }

    .site-footer__links { list-style: none; display: flex; flex-direction: column; gap: var(--space-2); }

    .site-footer__link {
      font-size: var(--text-sm);
      font-weight: 500;
      letter-spacing: 0.04em;
      color: var(--cd-text-muted);
      text-decoration: none;
      transition: color var(--ease-fast), padding-left var(--ease-fast);
      display: block;
      padding: 2px 0;
    }

    .site-footer__link:hover { color: var(--cd-neon-red); padding-left: var(--space-2); }

    /* Footer newsletter */
    .footer-newsletter { margin-top: var(--space-6); }

    .footer-newsletter__label {
      font-size: var(--text-sm);
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--cd-text-muted);
      margin-bottom: var(--space-3);
      display: block;
    }

    .footer-newsletter__form {
      display: flex;
      gap: 0;
    }

    .footer-newsletter__input {
      flex: 1;
      border-radius: 0;
      border-right: none;
      font-size: var(--text-sm);
    }

    .footer-newsletter__btn {
      background: var(--cd-neon-red);
      color: var(--cd-black);
      border: 1px solid var(--cd-neon-red);
      padding: var(--space-3) var(--space-4);
      font-family: var(--font-display);
      font-size: var(--text-base);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      cursor: pointer;
      white-space: nowrap;
      transition: background var(--ease-fast), color var(--ease-fast);
      flex-shrink: 0;
    }

    .footer-newsletter__btn:hover { background: var(--cd-blood-red); border-color: var(--cd-blood-red); color: var(--cd-white); }

    /* Footer bottom */
    .site-footer__bottom {
      border-top: 1px solid var(--cd-surface-3);
      padding: var(--space-4) 0;
    }

    .site-footer__bottom-inner {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 var(--page-padding);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: var(--space-4);
    }

    .site-footer__copy {
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      color: var(--cd-text-ghost);
      letter-spacing: 0.06em;
    }

    .site-footer__bottom-links {
      display: flex;
      gap: var(--space-4);
    }

    .site-footer__bottom-link {
      font-size: var(--text-xs);
      color: var(--cd-text-ghost);
      text-decoration: none;
      letter-spacing: 0.06em;
      transition: color var(--ease-fast);
    }
    .site-footer__bottom-link:hover { color: var(--cd-neon-red); }

    /* Payment icons row */
    .site-footer__payments {
      display: flex;
      align-items: center;
      gap: var(--space-3);
    }

    .payment-icon {
      height: 24px;
      opacity: 0.4;
      filter: grayscale(1);
      transition: opacity var(--ease-fast), filter var(--ease-fast);
    }

    .payment-icon:hover { opacity: 0.8; filter: grayscale(0); }

    /* ============================================================
       RESPONSIVE
    ============================================================ */
    @media (max-width: 1024px) {
      .site-footer__grid { grid-template-columns: 1fr 1fr; gap: var(--space-8); }
    }

    @media (max-width: 768px) {
      .site-nav       { display: none; }
      .hamburger      { display: flex; }

      .site-footer__grid { grid-template-columns: 1fr; gap: var(--space-8); }
      .site-footer__bottom-inner { flex-direction: column; text-align: center; }
      .site-footer__bottom-links { flex-wrap: wrap; justify-content: center; }
    }
  </style>

  <!-- Linked stylesheets -->
  {{ 'animations.css' | asset_url | stylesheet_tag }}
  {{ 'theme.css'      | asset_url | stylesheet_tag }}

  <!-- ============================================================
       STRUCTURED DATA
  ============================================================ -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": {{ shop.url | json }}
    {%- if settings.social_instagram_link != blank -%}
    ,"sameAs": [{{ settings.social_instagram_link | json }}]
    {%- endif -%}
  }
  </script>

  {%- if request.page_type == 'index' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": {{ shop.name | json }},
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": {{ routes.search_url | append: '?q={search_term_string}' | json }}
      },
      "query-input": "required name=search_term_string"
    },
    "url": {{ shop.url | json }}
  }
  </script>
  {%- endif -%}

  {%- if request.page_type == 'product' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | json }},
    "image": {{ product.featured_image | image_url: width: 800 | json }},
    "brand": {
      "@type": "Brand",
      "name": {{ shop.name | json }}
    },
    "offers": {
      "@type": "Offer",
      "price": {{ product.price | money_without_currency | json }},
      "priceCurrency": {{ cart.currency.iso_code | json }},
      "availability": {% if product.available %}"https://schema.org/InStock"{% else %}"https://schema.org/OutOfStock"{% endif %},
      "url": {{ canonical_url | json }}
    }
  }
  </script>
  {%- endif -%}

</head>

<body id="body" class="{% if request.page_type %}template-{{ request.page_type }}{% endif %}">

  <!-- JS detection -->
  <script>document.documentElement.classList.replace('no-js','js');</script>

  <!-- Page overlay (for cart drawer) -->
  <div class="overlay" id="overlay" aria-hidden="true"></div>

  <div class="page-wrapper">

    <!-- ============================================================
         ANNOUNCEMENT BAR
    ============================================================ -->
    <div class="announcement-bar" id="announcementBar" role="banner">
      <div class="announcement-bar__track" id="announceTrack">
        <!-- Duplicated for seamless loop -->
        {%- assign announce_text = settings.announcement_text | default: 'Free shipping on orders over $75 • New drops every Friday • Limited stock — act fast • Elevate your energy' -%}
        {%- assign items = announce_text | split: ' • ' -%}
        {%- for item in items -%}
          <span class="announcement-bar__item">{{ item }}</span>
        {%- endfor -%}
        {%- for item in items -%}
          <span class="announcement-bar__item">{{ item }}</span>
        {%- endfor -%}
      </div>
      <button class="announcement-bar__close" id="announceClose" aria-label="Close announcement">×</button>
    </div>

    <!--                <li><a href="{{ routes.collections_url }}" class="site-footer__link">All Products</a></li>
                <li><a href="{{ routes.collections_url }}/new-arrivals" class="site-footer__link">New Arrivals</a></li>
                <li><a href="{{ routes.collections_url }}/sale" class="site-footer__link">Sale</a></li>
              {%- endif -%}
            </ul>
          </div>

          <!-- Help links -->
          <div>
            <h4 class="site-footer__col-title">Help</h4>
            <ul class="site-footer__links">
              {%- if linklists['footer-help'] != blank -%}
                {%- for link in linklists['footer-help'].links -%}
                  <li><a href="{{ link.url }}" class="site-footer__link">{{ link.title }}</a></li>
                {%- endfor -%}
              {%- else -%}
                <li><a href="/pages/faq" class="site-footer__link">FAQ</a></li>
                <li><a href="/pages/shipping" class="site-footer__link">Shipping Info</a></li>
                <li><a href="/pages/returns" class="site-footer__link">Returns</a></li>
                <li><a href="/pages/contact" class="site-footer__link">Contact Us</a></li>
              {%- endif -%}
            </ul>
          </div>

          <!-- About links -->
          <div>
            <h4 class="site-footer__col-title">About</h4>
            <ul class="site-footer__links">
              {%- if linklists['footer-about'] != blank -%}
                {%- for link in linklists['footer-about'].links -%}
                  <li><a href="{{ link.url }}" class="site-footer__link">{{ link.title }}</a></li>
                {%- endfor -%}
              {%- else -%}
                <li><a href="/pages/about" class="site-footer__link">Our Story</a></li>
                <li><a href="/blogs/news" class="site-footer__link">Blog</a></li>
                <li><a href="/pages/sustainability" class="site-footer__link">Sustainability</a></li>
              {%- endif -%}
            </ul>
          </div>

        </div>
      </div>

      <!-- Footer bottom bar -->
      <div class="site-footer__bottom">
        <div class="site-footer__bottom-inner">
          <p class="site-footer__copy">
            &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
          </p>
          <div class="site-footer__bottom-links">
            <a href="/policies/privacy-policy" class="site-footer__bottom-link">Privacy</a>
            <a href="/policies/terms-of-service" class="site-footer__bottom-link">Terms</a>
            <a href="/policies/refund-policy" class="site-footer__bottom-link">Refunds</a>
          </div>
          <div class="site-footer__payments">
            {{ shop.enabled_payment_types | payment_type_svg_tag: class: 'payment-icon' }}
          </div>
        </div>
      </div>
    </footer>

  </div><!-- end .page-wrapper -->

  <!-- ============================================================
       JAVASCRIPT
  ============================================================ -->
  <script>
  (function() {
    'use strict';

    // â”€â”€ Announcement Bar â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    var announceBar   = document.getElementById('announcementBar');
    var announceClose = document.getElementById('announceClose');
    var ANNOUNCE_KEY  = 'cd_announce_closed';

    if (sessionStorage.getItem(ANNOUNCE_KEY) === '1') {
      announceBar.style.display = 'none';
      document.documentElement.style.setProperty('--announce-height', '0px');
    } else {
      announceClose.addEventListener('click', function() {
        announceBar.style.display = 'none';
        document.documentElement.style.setProperty('--announce-height', '0px');
        sessionStorage.setItem(ANNOUNCE_KEY, '1');
      });
    }

    // â”€â”€ Header scroll state â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    var siteHeader = document.getElementById('siteHeader');
    var ticking    = false;

    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(function() {
          siteHeader.classList.toggle('is-scrolled', window.scrollY > 40);
          ticking = false;
        });
        ticking = true;
      }
    }

    window.addEventListener('scroll', onScroll, { passive: true });

    // â”€â”€ Mobile Nav â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    var hamburger = document.getElementById('hamburger');
    var mobileNav = document.getElementById('mobileNav');

    hamburger.addEventListener('click', function() {
      var isOpen = hamburger.classList.toggle('is-open');
      mobileNav.classList.toggle('is-open', isOpen);
      hamburger.setAttribute('aria-expanded', isOpen);
      mobileNav.setAttribute('aria-hidden', !isOpen);
    });

    // â”€â”€ Cart Drawer â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    var cartTrigger = document.getElementById('cartTrigger');
    var cartDrawer  = document.getElementById('cartDrawer');
    var cartClose   = document.getElementById('cartClose');
    var overlay     = document.getElementById('overlay');

    function openCart() {
      cartDrawer.classList.add('is-open');
      overlay.classList.add('is-active');
      cartTrigger.setAttribute('aria-expanded', 'true');
      cartDrawer.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeCart() {
      cartDrawer.classList.remove('is-open');
      overlay.classList.remove('is-active');
      cartTrigger.setAttribute('aria-expanded', 'false');
      cartDrawer.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    cartTrigger.addEventListener('click', openCart);
    cartClose.addEventListener('click', closeCart);
    overlay.addEventListener('click', closeCart);

    // Escape key closes everything
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeCart();
        if (hamburger.classList.contains('is-open')) {
          hamburger.click();
        }
      }
    });

    // â”€â”€ Cart quantity / remove (AJAX) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    var cartBody = document.getElementById('cartBody');

    if (cartBody) {
      cartBody.addEventListener('click', function(e) {
        var target = e.target;

        // Quantity buttons
        if (target.classList.contains('cart-item__qty-btn')) {
          var cartItem = target.closest('.cart-item');
          var line     = cartItem.dataset.line;
          var action   = target.dataset.action;
          var qtyEl    = cartItem.querySelector('.cart-item__qty-val');
          var qty      = parseInt(qtyEl.textContent, 10);

          qty = action === 'increase' ? qty + 1 : Math.max(0, qty - 1);
          updateCartLine(line, qty);
        }

        // Remove button
        if (target.classList.contains('cart-item__remove')) {
          var line = target.dataset.line;
          updateCartLine(line, 0);
        }
      });
    }

    function updateCartLine(line, qty) {
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: line, quantity: qty })
      })
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        // Update count badge
        var countEl = document.getElementById('cartCount');
        if (countEl) {
          countEl.textContent = cart.item_count;
          countEl.classList.toggle('has-items', cart.item_count > 0);
        }
        // Reload drawer â€” full page section approach
        return fetch('/?section_id=cart-drawer');
      })
      .then(function(r) { return r.text(); })
      .catch(function() {
        // Fallback: reload page
        window.location.reload();
      });
    }

    // â”€â”€ Add-to-cart event (dispatch from product sections) â”€â”€â”€â”€â”€â”€â”€
    document.addEventListener('cart:updated', function(e) {
      var countEl = document.getElementById('cartCount');
      if (countEl && e.detail && e.detail.item_count !== undefined) {
        countEl.textContent = e.detail.item_count;
        countEl.classList.toggle('has-items', e.detail.item_count > 0);
      }
      openCart();
    });

  })();
  </script>

